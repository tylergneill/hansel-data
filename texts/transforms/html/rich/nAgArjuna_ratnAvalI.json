            "inline_text": null,
            "content_html": "<table>\n<thead>\n<tr>\n<th>#</th>\n<th>Pariccheda</th>\n<th>Phurtstham edition</th>\n<th>Dunne-McClintock 2024 transl.</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>1</td>\n<td>Abhyudayanaiḥśreyasopāya</td>\n<td>65</td>\n<td>77</td>\n</tr>\n<tr>\n<td>2</td>\n<td>Miśraka</td>\n<td>108</td>\n<td>93</td>\n</tr>\n<tr>\n<td>3</td>\n<td>Bodhisaṃbhārasamāsa</td>\n<td>152</td>\n<td>109</td>\n</tr>\n<tr>\n<td>4</td>\n<td>Rājavṛttopadeśa</td>\n<td>195</td>\n<td>125</td>\n</tr>\n<tr>\n<td>5</td>\n<td>\"Pañcama\" (*Bodhisattvācāra)</td>\n<td>241</td>\n<td>141</td>\n</tr>\n</tbody>\n</table>\n"
