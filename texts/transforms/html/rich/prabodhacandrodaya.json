        {
            "type": "corrections",
            "count": 46,
            "rows": [
                {
                    "sic": "",
                    "corr": "ekam utpattisthānam",
                    "page": "1",
                    "line": "1",
                    "location_id": "1_1"
                },
                {
                    "sic": "",
                    "corr": "asmākaṃ kule kālarātrikalpā vidyā nāma rākṣasī samutpatsyata",
                    "page": "1",
                    "line": "1",
                    "location_id": "1_1"
                },
                {
                    "sic": "",
                    "corr": "pāpakāriṇa",
                    "page": "1",
                    "line": "1",
                    "location_id": "1_1"
                },
                {
                    "sic": "",
                    "corr": "ahaṃ tāvad gatayauvanā varṣīyasījātā | ayaṃ ca purāṇapuruṣaḥ svabhāvād eva viṣayarasavimukhaḥ | tataḥ svatanayam eva pārameśvarapade niveśayāmī",
                    "page": "1",
                    "line": "1",
                    "location_id": "1_1"
                },
                {
                    "sic": "",
                    "corr": "vatsa dambha pratijñātaṃ sāmātyena vivekena prabodhodayāya, preṣitāś ca teṣu teṣu tīrtheṣu śamadamādayaḥ | sa cāyam asmākam upasthitaḥ kulakṣayo, bhavadbhir avahitaiḥ pratikartavyaḥ | tatra pṛthivyāṃ paramaṃ muktikṣetraṃ vārāṇasī nāma nagarī | tad bhavāṃs tatra gatvā caturṇām apy āśramāṇāṃ niḥśreyasavighnāya prayatatāṃ",
                    "page": "2",
                    "line": "1",
                    "location_id": "2_1"
                },
                {
                    "sic": "",
                    "corr": "ātmāsti dehād vyatiriktamūrtir bhoktā sa lokāntaritaḥ phalānām |",
                    "page": "2",
                    "line": "1",
                    "location_id": "2_1"
                },
                {
                    "sic": "",
                    "corr": "yan nāsty eva tad asti vastv",
                    "page": "2",
                    "line": "1",
                    "location_id": "2_1"
                },
                {
                    "sic": "",
                    "corr": "yoginī viṣṇubhaktir bhavadbhir evāvahitair vihantavye",
                    "page": "2",
                    "line": "1",
                    "location_id": "2_1"
                },
                {
                    "sic": "",
                    "corr": "svasti! śrīvārāṇasyāṃ mahārājādhirājaparameśvaramahāmohapādān puruṣottamāyatanād madamānau sāṣṭāṅgapātaṃ praṇamya vijñāpayataḥ | yathā bhadram avyāhatam! anyac ca, devī śāntir mātrā śraddhayā saha, vivekasya dautyam āpannā, vivekasaṃgamāya devīm upaniṣadam ahar niśaṃ pratibodhayati | api ca kāmasahacaro 'pi, dharmo vairāgyādibhir upajapta iva lakṣyate | yataḥ, kāmād vibhidya kutaścin nigūḍhaḥ pracarati | tad etaj jñātvā, tatra devaḥ pramāṇam",
                    "page": "2",
                    "line": "1",
                    "location_id": "2_1"
                },
                {
                    "sic": "",
                    "corr": "durāśayo dharma ity asmābhir avagatam | tad asmin muhūrtam api na viśvasitavyam | dṛḍhaṃ baddhvā dhārayitavya",
                    "page": "2",
                    "line": "1",
                    "location_id": "2_1"
                },
                {
                    "sic": "",
                    "corr": "śraddhāyās tanayā",
                    "page": "2",
                    "line": "1",
                    "location_id": "2_1"
                },
                {
                    "sic": "",
                    "corr": "piśāca",
                    "page": "3",
                    "line": "1",
                    "location_id": "3_1"
                },
                {
                    "sic": "",
                    "corr": "strīmukhaṃ tu sadā śuci",
                    "page": "3",
                    "line": "1",
                    "location_id": "3_1"
                },
                {
                    "sic": "",
                    "corr": "ghorām",
                    "page": "4",
                    "line": "1",
                    "location_id": "4_1"
                },
                {
                    "sic": "",
                    "corr": "evaṃ asya durātmano mahāmohahatakasya mām avajñāya pravartamānasya samūlam unmūlanaṃ kariṣyamīti",
                    "page": "4",
                    "line": "1",
                    "location_id": "4_1"
                },
                {
                    "sic": "",
                    "corr": "gaccha, śraddhe, brūhi vivekam kāmakrodhādīnāṃ nirjayāyodyogaḥ kriyatām | tato vairāgyaṃ prādurbhaviṣyati | ahaṃ ca yathāsamayaṃ prāṇāyāmādyanuṣṭhānena yuṣmatsainyam anugrahīṣyāmi | ṛtaṃbharādayaś ca devyaḥ śāntyādikauśalenopaniṣaddevyā saṃgatasya bhavataḥ prabodhodayam anuvidhāsyantīti",
                    "page": "4",
                    "line": "1",
                    "location_id": "4_1"
                },
                {
                    "sic": "",
                    "corr": "asti rāḍhābhidhāno janapadaḥ | tatra bhāgīrathīparisarālaṃkārabhūte cakratīrthe, mīmāṃsānugatayā matyā kathañcid dhāryamāṇaprāṇo, vyākulenāntarātmanā, viveka upaniṣaddevyāḥ saṃgamārthaṃ tapasyatīti",
                    "page": "4",
                    "line": "1",
                    "location_id": "4_1"
                },
                {
                    "sic": "",
                    "corr": "udyogaḥ kriyatām kāmādivijaye | tad aham api bhavadarthe gṛhītapakṣāiveti",
                    "page": "4",
                    "line": "1",
                    "location_id": "4_1"
                },
                {
                    "sic": "",
                    "corr": "vatse, śraddhe! aham atra hiṃsāprāyasamaradarśanaparāṅmukhī | tena vārāṇasīm utsṛjya, sālagrāmābhidhāne bhagavataḥ kṣetre kañcit kālam ativāhayāmi | tvaṃ tu yathāvṛttam samaravṛttāntam āgatya me nivedayiṣyasīti |",
                    "page": "5",
                    "line": "1",
                    "location_id": "5_1"
                },
                {
                    "sic": "",
                    "corr": "anubhavatv asya durnayaparipākasya phalaṃ vivekahataka!",
                    "page": "5",
                    "line": "1",
                    "location_id": "5_1"
                },
                {
                    "sic": "",
                    "corr": "sakhi, sarasvati | gacchāpatyavyasanakhinnasya manasaḥ prabodhanāya | yathā ca tasya vairāgyotpattir bhavati tathā yatasveti |",
                    "page": "5",
                    "line": "1",
                    "location_id": "5_1"
                },
                {
                    "sic": "",
                    "corr": "nigraha",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "anugrahaḥ",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "ś1āghyam etad",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "svasti viṣayebhya!",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "vivekaṃ draṣṭum icchāmīti |",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "bhartā svāmī ca puruṣas tvayā yathāpraśnam uttareṇa saṃbhāvayitavyaḥ, yathā prabodhotpattir bhaviṣyatīti",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "he putrakāḥ! saṃśṛṇutety",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "api nāmāiṣā pustakabhāravāhinī me jñāsyati tattvam",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "bhadre, kiṃ te samīhitam?",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "ārye! anāthāsmi | tvayi nivastum icchāmīti |",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "bhadre! kiṃ te karmeti?",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "tan manye nātiprayojanaṃ bhavatyāḥ parigraheṇa | tathāpi yadi kartāraṃ bhoktāraṃ puruṣaṃ stuvantī kiyantaṃ kālam atra vastum icchasi ko doṣaḥ?",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "sakhi! tvatsaṃnikarṣād durvāsanopahatair asmadantevāsibhiḥ karmasu ślathādarair bhavitavyam | tat prasīdatu bhavatī svābhilaṣitadeśagamanāya |",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "bhadre, kiṃ karmāsīti?",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "yasmād viśvam",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "asty evāsmākam lokāntaraphalopabhogayogyapuruṣopanayanenopayogaḥ | tat dhriyatām karmopayukteti!",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "devi! neyaṃ karmopayuktaṃ puruṣam upanayati | kintu akartāram, abhoktāram, īśvaram, na cāsāv īśvaraḥ karmasūpayujyate |",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "atha kiṃ laukikāt puruṣād anya īśvaro nāmāsti?",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "yasmād viśvam",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "āḥ vācāle! paramāṇubhyo viśvam utpadyate | nimittakāraṇam īśvaraḥ |",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "āḥ pāpe! katham īśvaram eva vikāriṇam kṛtvā vināśadharmiṇam upapādayasi? nanu re pradhānād viśvotpattiḥ |",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "aho! viśvavilayena muktim eṣā vadantī! nāstikapathaṃ prasthitā nigṛhyatām!",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "mātar! mātar!",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "nigūḍham asmadabhiprāyam upaniṣad vivekena saha bodhayitavyā | tvayā ca puruṣeṇa vastavyam",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                },
                {
                    "sic": "",
                    "corr": "saṃkalpayonayo devatā bhavanti | mayā ca samādhānena viditaṃ tathā āpannasattvā bhavatīti | tatra ca krūrasattvā vidyā nāma kanyā tvadudare vartate prabodhacandraś ca | tatra vidyāṃ saṅkarṣaṇavidyayā manasi saṅkrāmayiṣyasi | prabodhacandraṃ puruṣe samarpya vatsavivekena saha matsamīpam āgamiṣyasīti |",
                    "page": "6",
                    "line": "1",
                    "location_id": "6_1"
                }
            ]
        }
